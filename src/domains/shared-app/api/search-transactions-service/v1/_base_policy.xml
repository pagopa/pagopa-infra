<policies>
    <inbound>
      <base />
      <!-- rate limit by subscription key -->
      <rate-limit calls="10" renewal-period="5" remaining-calls-variable-name="remainingCallsPerSubscription"/>
      <set-variable name="nav" value="@(context.Request.MatchedParameters["nav"])" />
      <choose>
        <when condition="@(((string)context.Variables["nav"]).StartsWith("399"))">
          <set-backend-service base-url="https://${hostname}/pagopa-biz-events-service" />
        </when>
        <otherwise>
          <return-response>
            <set-status code="400"/>
            <set-header name="Content-Type" exists-action="override">
              <value>application/json</value>
            </set-header>
            <set-body>@{
              return new JObject(
              new JProperty("title", "Forbidden"),
              new JProperty("status", 403),
              new JProperty("detail", "Invalid NAV matching"))
              .ToString();
              }
            </set-body>
          </return-response>
        </otherwise>
      </choose>
    </inbound>
    <outbound>
      <base />
    </outbound>
    <backend>
        <base />
    </backend>
    <on-error>
        <base />
    </on-error>
</policies>
