<policies>
    <inbound>
      <cors>
        <allowed-origins>
          <origin>${apim_origin_cie_search}</origin>
        </allowed-origins>
        <allowed-methods>
          <method>GET</method>
        </allowed-methods>
        <allowed-headers>
          <header>Authorization</header>
          <header>x-fiscal-code</header>
        </allowed-headers>
      </cors>
      <base />
      <rate-limit-by-key calls="10" renewal-period="5" counter-key="@(context.Request.Headers.GetValueOrDefault("X-Forwarded-For"))" remaining-calls-variable-name="remainingCallsPerIp"/>
      <set-variable name="authToken" value="@(context.Request.Headers.GetValueOrDefault("Authorization", "").Replace("Bearer ",""))" />
      <choose>
        <when condition="@(((string)context.Variables["authToken"]) != "{{search-transactions-token-secret-value}}")">
          <return-response>
            <set-status code="401"/>
            <set-header name="Content-Type" exists-action="override">
              <value>application/json</value>
            </set-header>
            <set-body>@{
              return new JObject(
              new JProperty("title", "Unauthorized"),
              new JProperty("status", 401),
              new JProperty("detail", "Invalid Token"))
              .ToString();
              }
            </set-body>
          </return-response>
        </when>
      </choose>
      <set-variable name="nav" value="@(context.Request.MatchedParameters["nav"])" />
      <choose>
        <when condition="@(((string)context.Variables["nav"]).StartsWith("${cie_search_segragation_code}"))">
          <set-backend-service base-url="https://${hostname}/pagopa-biz-events-service" />
        </when>
        <otherwise>
          <return-response>
            <set-status code="403"/>
            <set-header name="Content-Type" exists-action="override">
              <value>application/json</value>
            </set-header>
            <set-body>@{
              return new JObject(
              new JProperty("title", "Forbidden"),
              new JProperty("status", 403),
              new JProperty("detail", "Invalid NAV matching"))
              .ToString();
              }
            </set-body>
          </return-response>
        </otherwise>
      </choose>
    </inbound>
    <outbound>
      <base />
    </outbound>
    <backend>
        <base />
    </backend>
    <on-error>
        <base />
    </on-error>
</policies>
