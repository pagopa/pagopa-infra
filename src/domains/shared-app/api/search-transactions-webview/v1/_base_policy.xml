<policies>
    <inbound>
      <cors>
        <allowed-methods>
          <method>GET</method>
          <method>POST</method>
          <method>OPTIONS</method>
          <method>HEAD</method>
        </allowed-methods>
        <allowed-origins>
          <origin>*</origin>
        </allowed-origins>
        <allowed-headers>
          <header>*</header>
        </allowed-headers>
      </cors>
      <base />
      <rate-limit-by-key calls="100" renewal-period="50" counter-key="@(context.Request.Headers.GetValueOrDefault("X-Forwarded-For"))" />
      <set-backend-service base-url="https://${hostname}/pagopa-search-transactions-fe/" />
    </inbound>
    <outbound>
      <base />
    </outbound>
    <backend>
      <base />
    </backend>
    <on-error>
      <base />
    </on-error>
  </policies>
