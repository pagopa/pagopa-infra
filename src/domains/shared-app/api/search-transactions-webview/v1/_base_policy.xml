<policies>
    <inbound>
      <cors>
        <allowed-methods>
          <method>GET</method>
        </allowed-methods>
        <allowed-origins>
          <origin>${search_transactions_origin}</origin>
        </allowed-origins>
        <allowed-headers>
          <header>${search_transactions_header}</header>
        </allowed-headers>
      </cors>
      <base />
      <rate-limit-by-key calls="100" renewal-period="50" counter-key="@(context.Request.Headers.GetValueOrDefault("X-Forwarded-For"))" />
      <set-variable name="token" value="@(context.Request.Url.Query.GetValueOrDefault("token", ""))" />
      <choose>
        <when condition="@(((string)context.Variables["token"]) != "{{search-transactions-token-secret-webview-value}}")">
          <return-response>
            <set-status code="403"/>
            <set-header name="Content-Type" exists-action="override">
              <value>application/json</value>
            </set-header>
            <set-body>@{
              return new JObject(
              new JProperty("title", "Unauthorized"),
              new JProperty("status", 401),
              new JProperty("detail", "Invalid Token matching"))
              .ToString();
              }
            </set-body>
          </return-response>
        </when>
      </choose>
      <set-backend-service base-url="https://${hostname}/search-transactions" />
    </inbound>
    <outbound>
      <base />
    </outbound>
    <backend>
      <base />
    </backend>
    <on-error>
      <base />
    </on-error>
  </policies>
