<policies>
    <inbound>
      <cors>
        <allowed-methods>
          <method>GET</method>
        </allowed-methods>
        <allowed-headers>
        </allowed-headers>
      </cors>
      <base />
      <rate-limit-by-key calls="100" renewal-period="50" counter-key="@(context.Request.Headers.GetValueOrDefault("X-Forwarded-For"))" />
    </inbound>
    <outbound>
      <base />
    </outbound>
    <backend>
      <base />
    </backend>
    <on-error>
      <base />
    </on-error>
  </policies>
