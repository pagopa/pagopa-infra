<policies>
    <inbound>
        <base />

        <return-response>
            <set-status code="403" reason="Forbidden" />
            <set-header name="Content-Type" exists-action="override">
                <value>application/json</value>
            </set-header>
            <set-body>@{
                return @"{
                ""httpStatusCode"": 403,
                ""httpStatusDescription"": ""Forbidden"",
                ""appErrorCode"": ""FDR-0500"",
                ""errors"": []
                }";
                }</set-body>
        </return-response>

    </inbound>
    <backend>
        <base />
    </backend>
    <outbound>
        <base />
    </outbound>
    <on-error>
        <base />
    </on-error>
</policies>
